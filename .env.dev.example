# Example development environment configuration
# Copy this to .env.dev and fill in your values

# Strava credentials
STRAVA_OAUTH_URL=https://www.strava.com/oauth/authorize
STRAVA_TOKEN_URL=https://www.strava.com/oauth/token
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret

# MapMyFitness timezone for parsing uploaded CSV timestamps (optional, defaults to America/Chicago)
MMF_TIMEZONE=America/Chicago

# Google Calendar API credentials (optional)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# Hevy API key for lifting data sync (optional)
HEVY_API_KEY=your_hevy_api_key

# OAuth Identity Provider
IDENTITY_PROVIDER_URL=http://localhost:8080
JWT_ISSUER=http://localhost:8080
JWT_AUDIENCE=http://localhost:8000

# TRMNL API Key (for device authentication to /summary/trmnl endpoint)
TRMNL_API_KEY=your_trmnl_api_key

# Secret for signing OAuth `state` CSRF tokens. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
OAUTH_STATE_SECRET=your_oauth_state_secret

# Public URLs
PUBLIC_API_BASE_URL=http://localhost:8000
PUBLIC_DASHBOARD_BASE_URL=http://localhost:5173

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Database connection
DATABASE_URL=postgresql://user:password@host:5432/database
